# OpenAI-compatible API settings
# Copy this file to .env and fill in your own values.

# Required when NOVEL_MOCK=0
OPENAI_API_KEY=

# Model name. You can use OpenAI models or compatible third-party model names.
NOVEL_LLM_MODEL=gpt-4o-mini

# Optional custom API endpoint, for OpenAI-compatible providers.
OPENAI_API_BASE=
OPENAI_BASE_URL=

# Set to 1 to use mock data without calling a real model.
NOVEL_MOCK=0

# Fast generation mode switches.
# These keep high-frequency review, continuity, and memory updates local by default.
NOVEL_FAST_REVIEW=1
NOVEL_FAST_CONTINUITY=1
NOVEL_FAST_MEMORY=1
NOVEL_REPAIR_MAX_ROUNDS=2
